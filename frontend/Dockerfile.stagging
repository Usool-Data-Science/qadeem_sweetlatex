FROM node:20-alpine AS builder
WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

RUN npm run build

# ── production stage ──
FROM nginx:alpine
COPY --from=builder /app/dist/ /usr/share/nginx/html
COPY nginx.local.conf /etc/nginx/conf.d/default.conf

# copy Django static/media volumes at runtime via docker-compose volume mounts
EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]